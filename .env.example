# KnowTwin — environment template. Copy to .env and fill with real secrets.
# Generate secrets:  openssl rand -hex 32
# Generate ENCRYPTION_KEY (Fernet):  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

KNOWTWIN_ENV=development

# Postgres
KNOWTWIN_DB_PASSWORD=change_me

# Auth
KNOWTWIN_JWT_SECRET=change_me_random_32_bytes
KNOWTWIN_API_KEY_PEPPER=change_me_random_32_bytes

# CORS (api host + frontend host)
KNOWTWIN_CORS_ORIGINS=http://localhost:8090,http://localhost:3001

# Fernet key for LLM provider-key encryption (crypto.py). REQUIRED.
KNOWTWIN_ENCRYPTION_KEY=

# Internal SSE broadcast secret (worker → api). Optional at P1.1.
KNOWTWIN_INTERNAL_BROADCAST_SECRET=

# HuggingFace cache bind mount (reuse to avoid re-downloading Jina v4 ~7GB).
# HF_CACHE_PATH=/path/to/.cache/huggingface
